{
  "name": "ai-music-video-generator",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Containerized AI music video generation platform with Astro frontend and Express backend.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "up": "docker compose up --build -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f --tail=200",
    "bootstrap:suno": "bash scripts/bootstrap-suno.sh",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:api:curls": "bash scripts/test-api-curls.sh",
    "check": "npm run format:check && npm run lint && npm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md,yml,yaml,astro}": [
      "prettier --write"
    ],
    "apps/**/*.{js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}
