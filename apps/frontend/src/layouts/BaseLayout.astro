---
import '../styles/global.css';

const { title = 'AI Music Video Studio' } = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8080/api/v1';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Create AI-generated music videos end-to-end from one dashboard."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Newsreader:opsz,wght@6..72,400;6..72,500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-api-base={apiBase}>
    <a href="#main" class="skip-nav">Skip to main content</a>
    <slot />
  </body>
</html>
