# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Suno API service
SUNO_API_BASE_URL=http://suno-api:3000
SUNO_POLL_INTERVAL_MS=5000
SUNO_POLL_TIMEOUT_MS=900000
SUNO_COOKIE=

# Backend
API_PORT=8080
FRONTEND_ORIGIN=http://localhost:4321
WORKER_CONCURRENCY=2
FFMPEG_PATH=ffmpeg
NODE_ENV=development

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=music_video
POSTGRES_USER=music_video
POSTGRES_PASSWORD=music_video

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (S3 compatible)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=music-video-assets
MINIO_PUBLIC_BASE_URL=http://localhost:9000
